# ─── AirShield Backend Environment Variables ───────────────────
# Copy this file to .env and fill in your keys.

# OpenWeather Air Pollution API (free — 1,000 calls/day)
# Get your key at: https://openweathermap.org/api/air-pollution
OPENWEATHER_KEY=your_openweather_key_here

# OpenAQ API key (optional — increases rate limits significantly)
# Free registration at: https://openaq.org/developers/
OPENAQ_KEY=

# Server settings (change for production)
HOST=0.0.0.0
PORT=8000
